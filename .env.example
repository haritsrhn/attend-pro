# App / Next.js
NEXTAUTH_URL=
# The canonical URL of your deployed Next.js app, e.g. https://attendpro.vercel.app

NEXTAUTH_SECRET=
# Long, random string used by NextAuth.js to sign and encrypt JWTs.
# Generate with: openssl rand -hex 32

NODE_ENV=production
# Optional. Set to "production" in Vercel/hosted environments.

# Database / Prisma
DATABASE_URL=
# PostgreSQL connection string used by Prisma and Next.js API routes.
# Example (Supabase): postgres://USER:PASSWORD@HOST:PORT/DATABASE

